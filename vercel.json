{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0",
      "excludeFiles": "{assets/**,.opencode/**,*.html,*.md,*.txt}"
    }
  },
  "rewrites": [
    {
      "source": "/subscribe.php",
      "destination": "/api/subscribe.php"
    },
    {
      "source": "/mail.php",
      "destination": "/api/mail.php"
    }
  ]
}
